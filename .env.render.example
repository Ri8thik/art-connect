# Render environment variables for backend (Spring Boot)
# Copy these into Render -> Service -> Environment

# Database (Neon PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://neondb_owner:npg_JakDSPj6n5Ah@ep-noisy-meadow-apczzn87-pooler.c-7.us-east-1.aws.neon.tech/artconnectdb?sslmode=require&channel_binding=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=Bottle@88!
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# JPA / Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA=app
SPRING_JPA_OPEN_IN_VIEW=false

# JWT (generate a strong random secret)
JWT_SECRET=e25a8fbb36d8f9d9634cf20008fc387c98b20cb4e2494fd81b58e50e4e83ed03
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS (no trailing slash, comma-separated if multiple)
# Example: https://ri8thik.github.io,http://localhost:5173
CORS_ALLOWED_ORIGINS=<YOUR_FRONTEND_ORIGIN>

# Optional tuning for free-tier DB connections
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=1
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=30000

# Logging (optional)
LOGGING_LEVEL_COM_PROJECT_ARTCONNECT=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO

# NOTE:
# - Do not set PORT manually on Render; Render injects it.
# - Your app already supports server.port from PORT.

